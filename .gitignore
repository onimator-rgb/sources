# -----------------------------------------------
# Python
# -----------------------------------------------
__pycache__/
*.py[cod]
*.pyd
.Python
*.egg-info/
*.egg

# -----------------------------------------------
# Virtual environments
# -----------------------------------------------
venv/
.venv/
env/
.env/

# -----------------------------------------------
# PyInstaller build outputs
# -----------------------------------------------
build/
dist/
# Note: OH.spec is intentionally tracked — it is the build config.

# -----------------------------------------------
# OH runtime data (per-machine, never committed)
# -----------------------------------------------
oh.db
*.log

# -----------------------------------------------
# IDE / editor
# -----------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# -----------------------------------------------
# OS junk
# -----------------------------------------------
Thumbs.db
Desktop.ini
.DS_Store

# -----------------------------------------------
# Testing
# -----------------------------------------------
.pytest_cache/
.coverage
htmlcov/

# -----------------------------------------------
# Distribution & temp files
# -----------------------------------------------
OH_Distribution/
scripts/_screens/
logs/
*.png
*.lnk
.claude/settings.local.json

# -----------------------------------------------
# License keys (private key must NEVER be committed)
# -----------------------------------------------
.license_private_key
scripts/.license_private_key
license_*.key
